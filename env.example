# Copy to .env and fill in your values (or export these in your shell)
# For local testing only - GitHub Actions uses repository secrets

SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
NEWSLETTER_RECIPIENT=your@gmail.com

# MCP summarization - set one of these to enable AI summaries
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional - defaults to Gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
